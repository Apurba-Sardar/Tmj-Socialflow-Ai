generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum AuthTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum PinterestPublishStatus {
  QUEUED
  PROCESSING
  PUBLISHED
  FAILED
}

enum PinterestLogLevel {
  INFO
  WARN
  ERROR
}

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  passwordHash    String
  displayName     String?
  role            Role           @default(USER)
  emailVerifiedAt DateTime?
  disabledAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  refreshTokens   RefreshToken[]
  authTokens      AuthToken[]
  pinterestAccounts PinterestAccount[]
  pinterestOAuthStates PinterestOAuthState[]
  pinterestPublishJobs PinterestPublishJob[]

  @@index([role])
}

model PinterestAccount {
  id                    String                @id @default(cuid())
  userId                String
  pinterestUserId       String
  username              String?
  accessTokenCiphertext String
  refreshTokenCiphertext String?
  tokenExpiresAt        DateTime?
  scope                 String
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  publishJobs           PinterestPublishJob[]

  @@unique([userId, pinterestUserId])
  @@index([userId])
}

model PinterestOAuthState {
  id        String   @id @default(cuid())
  userId    String
  stateHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PinterestPublishJob {
  id             String                  @id @default(cuid())
  userId         String
  accountId      String
  boardId        String
  boardName      String?
  title          String
  description    String?
  mediaUrl       String
  link           String?
  altText        String?
  status         PinterestPublishStatus  @default(QUEUED)
  attempts       Int                     @default(0)
  pinterestPinId String?
  scheduledFor   DateTime?
  lastError      String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  publishedAt    DateTime?
  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account        PinterestAccount        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  logs           PinterestPublishLog[]
  analytics      PinterestPinAnalytics?

  @@index([userId, status])
  @@index([accountId])
  @@index([scheduledFor])
}

model PinterestPublishLog {
  id        String            @id @default(cuid())
  jobId     String
  level     PinterestLogLevel
  message   String
  metadata  Json?
  createdAt DateTime          @default(now())
  job       PinterestPublishJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([level])
}

model PinterestPinAnalytics {
  id          String   @id @default(cuid())
  jobId       String   @unique
  impressions Int      @default(0)
  saves       Int      @default(0)
  clicks      Int      @default(0)
  outboundClicks Int   @default(0)
  capturedAt  DateTime @default(now())
  job         PinterestPublishJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  familyId   String
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedBy String?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
}

model AuthToken {
  id        String        @id @default(cuid())
  userId    String
  type      AuthTokenType
  tokenHash String        @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([expiresAt])
}

model WordPressConnection {
  id                    String   @id @default(cuid())
  siteUrl               String
  username              String
  applicationPasswordIv String
  applicationPasswordTag String
  applicationPasswordCiphertext String
  isActive              Boolean  @default(true)
  lastConnectedAt       DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  articles              WordPressArticle[]
  syncRuns              WordPressSyncRun[]

  @@unique([siteUrl, username])
  @@index([isActive])
}

model WordPressRequestLog {
  id         String   @id @default(cuid())
  method     String
  url        String
  statusCode Int?
  attempts   Int
  durationMs Int
  success    Boolean
  error      String?
  createdAt  DateTime @default(now())

  @@index([success])
  @@index([createdAt])
}

enum WordPressSyncStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum SocialPlatform {
  PINTEREST
  INSTAGRAM
  LINKEDIN
  X
  FACEBOOK
}

enum SocialDraftStatus {
  DRAFT
  APPROVED
  SCHEDULED
  PUBLISHED
  REJECTED
}

model WordPressArticle {
  id              String              @id @default(cuid())
  connectionId    String
  wordpressId     Int
  slug            String
  status          String
  title           String
  excerpt         String
  contentHtml     String?
  contentText     String?
  url             String
  authorId        Int?
  authorName      String?
  authorSlug      String?
  featuredImageId Int?
  featuredImageUrl String?
  featuredImageAlt String?
  categoryNames   String[]
  categorySlugs   String[]
  publishedAt     DateTime?
  modifiedAt      DateTime?
  lastSyncedAt    DateTime            @default(now())
  repurposedAt    DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  connection      WordPressConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  repurposeJobs   ContentRepurposeJob[]
  socialDrafts    SocialDraft[]

  @@unique([connectionId, wordpressId])
  @@index([modifiedAt])
  @@index([repurposedAt])
  @@index([categorySlugs])
}

model WordPressSyncRun {
  id            String              @id @default(cuid())
  connectionId  String
  status        WordPressSyncStatus @default(RUNNING)
  startedAt     DateTime            @default(now())
  completedAt   DateTime?
  scannedPosts  Int                 @default(0)
  upsertedPosts Int                 @default(0)
  failedPosts   Int                 @default(0)
  error         String?
  connection    WordPressConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId, startedAt])
  @@index([status])
}

model ContentRepurposeJob {
  id         String           @id @default(cuid())
  articleId  String
  status     String           @default("COMPLETED")
  platforms  SocialPlatform[]
  prompt     String?
  error      String?
  createdAt  DateTime         @default(now())
  article    WordPressArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  drafts     SocialDraft[]

  @@index([articleId])
  @@index([createdAt])
}

model SocialDraft {
  id               String             @id @default(cuid())
  articleId        String
  repurposeJobId   String?
  platform         SocialPlatform
  status           SocialDraftStatus  @default(DRAFT)
  title            String
  body             String
  hashtags         String[]
  callToAction     String?
  mediaUrl         String?
  sourceUrl        String
  scheduledFor     DateTime?
  approvedAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  article          WordPressArticle   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  repurposeJob     ContentRepurposeJob? @relation(fields: [repurposeJobId], references: [id], onDelete: SetNull)

  @@index([platform, status])
  @@index([scheduledFor])
  @@index([articleId])
}
