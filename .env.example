NODE_ENV=development

POSTGRES_USER=socialflow
POSTGRES_PASSWORD=socialflow
POSTGRES_DB=socialflow_ai
DATABASE_URL=postgresql://socialflow:socialflow@localhost:5432/socialflow_ai?schema=public

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

API_PORT=4000
API_HOST=0.0.0.0
API_CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-characters
JWT_EMAIL_VERIFICATION_SECRET=change-me-email-secret-at-least-32-characters
JWT_PASSWORD_RESET_SECRET=change-me-reset-secret-at-least-32-characters
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
EMAIL_VERIFICATION_TTL_SECONDS=86400
PASSWORD_RESET_TTL_SECONDS=3600
BCRYPT_SALT_ROUNDS=12
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
APP_BASE_URL=http://localhost:3000
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="SocialFlow AI <no-reply@socialflow.ai>"

NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
