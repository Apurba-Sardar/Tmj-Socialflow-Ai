NODE_ENV=development

POSTGRES_USER=socialflow
POSTGRES_PASSWORD=socialflow
POSTGRES_DB=socialflow_ai
DATABASE_URL=postgresql://socialflow:socialflow@localhost:5432/socialflow_ai?schema=public
# For Supabase production/staging, replace DATABASE_URL with the Supabase Postgres pooler URL.
# Example: postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&schema=public
DIRECT_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GOOGLE_ANALYTICS_PROPERTY_ID=
GOOGLE_ANALYTICS_CLIENT_EMAIL=
# Keep the private key quoted and preserve \n line breaks when deploying to Vercel/Render/etc.
GOOGLE_ANALYTICS_PRIVATE_KEY=

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

API_PORT=4000
API_HOST=0.0.0.0
API_PUBLIC_URL=http://localhost:4000
API_CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-characters
JWT_EMAIL_VERIFICATION_SECRET=change-me-email-secret-at-least-32-characters
JWT_PASSWORD_RESET_SECRET=change-me-reset-secret-at-least-32-characters
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
EMAIL_VERIFICATION_TTL_SECONDS=86400
PASSWORD_RESET_TTL_SECONDS=3600
BCRYPT_SALT_ROUNDS=12
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
APP_BASE_URL=http://localhost:3000
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="SocialFlow AI <no-reply@socialflow.ai>"
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:4000/api/social-channels/oauth/PINTEREST/callback
PINTEREST_TOKEN_ENCRYPTION_KEY=change-me-pinterest-token-key-32chars
META_CLIENT_ID=
META_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:4000/api/social-channels/oauth/FACEBOOK/callback
INSTAGRAM_REDIRECT_URI=http://localhost:4000/api/social-channels/oauth/INSTAGRAM/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:4000/api/social-channels/oauth/LINKEDIN/callback
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:4000/api/social-channels/oauth/X/callback

NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
